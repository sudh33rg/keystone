{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "vscode", "vitest/globals"]
  },
  "include": ["src", "tests", "vite.config.ts", "vitest.config.ts"],
  "exclude": [
    "tests/fixtures/benchmarks/typescript-backend",
    "tests/fixtures/benchmarks/react-frontend",
    "tests/fixtures/benchmarks/fullstack",
    "tests/fixtures/benchmarks/multi-package",
    "tests/fixtures/intelligence",
    "src/core/persistence/OkfConceptStore.ts"
  ]
}
