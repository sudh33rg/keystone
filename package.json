{
  "name": "keystone",
  "displayName": "Keystone",
  "description": "A visible engineering control layer for repository-aware, spec-driven Copilot work.",
  "version": "0.1.0",
  "publisher": "keystone-dev",
  "engines": {
    "vscode": "^1.95.0",
    "node": ">=20"
  },
  "author": "Sudheer G",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:keystone.open"
  ],
  "main": "./dist/extension/extension.js",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build:extension": "node scripts/build-extension.mjs",
    "build:extension-tests": "node scripts/build-extension-tests.mjs",
    "build:webview": "vite build",
    "build": "npm run clean && npm run build:extension && npm run build:webview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:extension": "npm run build && npm run build:extension-tests && node scripts/run-extension-tests.mjs",
    "test:watch": "vitest",
    "test:intelligence-benchmark": "node --experimental-strip-types tests/fixtures/benchmarks/run-benchmarks.ts",
    "verify": "npm run typecheck && npm test && npm run build",
    "package": "npm run verify && vsce package --allow-missing-repository --no-dependencies --baseContentUrl . --baseImagesUrl .",
    "audit": "npm audit --audit-level=high"
  },
  "contributes": {
    "chatParticipants": [
      {
        "id": "keystone.chat",
        "name": "keystone",
        "fullName": "Keystone",
        "description": "Deterministic repository and workflow questions from local Keystone Intelligence",
        "isSticky": true
