              "type": "number",
              "minimum": 1,
              "maximum": 100
            },
            "timeoutMs": {
              "type": "number",
              "minimum": 100,
              "maximum": 15000
            }
          },
          "required": [
            "repositoryId"
          ],
          "additionalProperties": false
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "keystone",
          "title": "Keystone",
          "icon": "resources/keystone.svg"
        }
      ]
    },
    "views": {
      "keystone": [
        {
          "id": "keystone.dashboard",
          "name": "Dashboard"
        },
        {
          "id": "keystone.explorer",
          "name": "Intelligence Explorer"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "keystone.dashboard",
        "contents": "Open a folder to use repository-aware Keystone features.\n[Open Folder](command:keystone.openFolder)\n\n[Open Keystone](command:keystone.open)",
        "when": "!keystone.workspaceAvailable"
      },
      {
        "view": "keystone.explorer",
        "contents": "Intelligence Explorer requires an indexed repository.\n[Open Intelligence Explorer](command:keystone.intelligence.open)",
        "when": "keystone.intelligenceReady"
      }
    ],
    "commands": [
      {
        "command": "keystone.open",
        "title": "Keystone: Open",
        "icon": "$(inspect)"
      },
      {
        "command": "keystone.startWorkflow",
        "title": "Keystone: Start New Work",
        "icon": "$(add)"
      },
      {
        "command": "keystone.resumeWorkflow",
        "title": "Keystone: Resume Current Workflow",
        "icon": "$(debug-continue)"
      },
      {
        "command": "keystone.openCurrentTask",
        "title": "Keystone: Open Current Task",
        "icon": "$(tools)"
      },
      {
        "command": "keystone.askRepository",
        "title": "Keystone: Ask Repository",
        "icon": "$(search)"
      },
      {
        "command": "keystone.openEntity",
        "title": "Keystone: Open Entity",
        "icon": "$(symbol-class)"
      },
      {
        "command": "keystone.showUsages",
        "title": "Keystone: Show Usages",
        "icon": "$(references)"
      },
      {
        "command": "keystone.showFlow",
        "title": "Keystone: Show Flow",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "keystone.analyzeImpact",
        "title": "Keystone: Analyze Impact",
        "icon": "$(pulse)"
      },
      {
        "command": "keystone.importHandoff",
        "title": "Keystone: Import Task Handoff",
        "icon": "$(cloud-download)"
      },
      {
        "command": "keystone.showLogs",
        "title": "Keystone: Show Logs",
        "icon": "$(output)"
      },
      {
        "command": "keystone.dashboard.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "keystone.dashboard.openAction",
        "title": "Open Dashboard Item"
      },
      {
        "command": "keystone.openFolder",
        "title": "Open Folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "keystone.intelligence.open",
        "title": "Keystone: Open Intelligence Explorer",
        "icon": "$(graph)"
      },
      {
        "command": "keystone.copilot.toggle",
        "title": "Keystone: Toggle Copilot Markdown Generation",
        "icon": "$(copilot)"
      },
      {
        "command": "keystone.graph.index",
        "title": "Keystone: Index Graph",
        "icon": "$(database)"
      },
      {
        "command": "keystone.graph.cancel",
        "title": "Keystone: Cancel Graph Indexing",
        "icon": "$(debug-stop)"
      },
      {
        "command": "keystone.git.history",
        "title": "Keystone: Parse Git History",
        "icon": "$(history)"
      },
      {
        "command": "keystone.safety.check",
        "title": "Keystone: Check Git Safety",
        "icon": "$(shield)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "keystone.dashboard.refresh",
          "when": "view == keystone.dashboard",
          "group": "navigation"
        },
        {
          "command": "keystone.open",
          "when": "view == keystone.dashboard",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "keystone.openEntity",
          "when": "keystone.intelligenceReady && keystone.workspaceTrusted && config.keystone.shell.showEditorContextActions",
          "group": "navigation@51"
        },
        {
          "command": "keystone.showUsages",
          "when": "keystone.intelligenceReady && keystone.workspaceTrusted && config.keystone.shell.showEditorContextActions",
          "group": "navigation@52"
        },
        {
          "command": "keystone.showFlow",
          "when": "keystone.intelligenceReady && keystone.workspaceTrusted && config.keystone.shell.showEditorContextActions",
          "group": "navigation@53"
        },
        {
          "command": "keystone.analyzeImpact",
          "when": "keystone.intelligenceReady && keystone.workspaceTrusted && config.keystone.shell.showEditorContextActions",
          "group": "navigation@54"
        }
      ],
      "commandPalette": [
        {
          "command": "keystone.dashboard.openAction",
          "when": "false"
        },
        {
          "command": "keystone.dashboard.refresh",
          "when": "false"
        },
        {
          "command": "keystone.openFolder",
          "when": "false"
        },
        {
          "command": "keystone.intelligence.open",
          "when": "keystone.intelligenceReady"
        },
        {
          "command": "keystone.copilot.toggle"
        },
        {
          "command": "keystone.graph.index",
          "when": "keystone.intelligenceReady"
        },
        {
          "command": "keystone.graph.cancel",
          "when": "keystone.intelligenceReady"
        },
        {
          "command": "keystone.git.history",
          "when": "keystone.intelligenceReady"
        },
        {
          "command": "keystone.safety.check"
        }
      ]
    },
    "configuration": {
      "title": "Keystone",
      "properties": {
        "keystone.panel.reopenOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Restore the Keystone panel when it was open in the previous VS Code session."
        },
        "keystone.panel.defaultColumn": {
          "type": "string",
          "enum": [
            "one",
            "active",
            "beside"
          ],
          "default": "one",
          "description": "Default editor column used when Keystone creates its singleton panel."
        },
        "keystone.shell.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show one compact Keystone status item for current repository and workflow state."
        },
        "keystone.shell.showEditorContextActions": {
          "type": "boolean",
          "default": true,
          "description": "Show entity, usage, flow, and impact actions for supported source files."
        },
        "keystone.shell.enableCodeLens": {
          "type": "boolean",
          "default": false,
          "description": "Show bounded Keystone Intelligence CodeLens actions above supported symbols."
        },
        "keystone.shell.dashboardRefreshDebounceMs": {
          "type": "number",
          "default": 150,
          "minimum": 50,
          "maximum": 2000,
          "description": "Debounce interval for event-driven native dashboard refreshes."
        },
        "keystone.indexing.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable local repository indexing."
        },
        "keystone.indexing.onWorkspaceOpen": {
          "type": "boolean",
          "default": true,
          "description": "Start local intelligence reconciliation after the workspace opens."
        },
        "keystone.indexing.onBranchChange": {
          "type": "boolean",
          "default": true,
          "description": "Refresh repository intelligence after a branch change."
        },
        "keystone.indexing.maxFileSizeKb": {
          "type": "number",
          "default": 1024,
          "minimum": 1,
          "description": "Maximum file size considered during indexing."
        },
        "keystone.indexing.maxFiles": {
          "type": "number",
          "default": 100000,
          "minimum": 1,
          "description": "Maximum number of files considered in one repository index."
        },
        "keystone.indexing.workerCount": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 32,
          "description": "Persistent intelligence worker count. Use 0 for the low-impact automatic default (two utility workers plus one semantic worker)."
        },
        "keystone.indexing.retainedGenerations": {
          "type": "number",
          "default": 2,
          "minimum": 2,
          "maximum": 20,
          "description": "Number of complete local intelligence generations retained for recovery."
        },
        "keystone.indexing.exclusions": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional glob patterns excluded from repository intelligence."
        },
        "keystone.context.maxEstimatedTokens": {
          "type": "number",
          "default": 12000,
          "minimum": 1000,
          "description": "Soft token budget for one task context package."
        },
        "keystone.context.includeTests": {
          "type": "boolean",
          "default": true,
          "description": "Include related tests when preparing context."
        },
        "keystone.workflow.defaultMode": {
          "type": "string",
          "enum": [
            "quick",
            "guided",
            "spec-driven"
          ],
          "default": "guided",
          "description": "Default intent workflow mode."
        },
        "keystone.workflow.requireSpecApproval": {
          "type": "boolean",
          "default": true,
          "description": "Require explicit specification approval before implementation."
        },
        "keystone.agents.selectionMode": {
          "type": "string",
          "enum": [
            "manual",
            "recommended",
            "rule-based",
            "fixed-workflow"
          ],
          "default": "recommended",
          "description": "Default Copilot agent-selection policy."
        },
        "keystone.agents.profiles": {
          "type": "array",
          "default": [],
          "description": "Inert, schema-validated agent metadata. Configuration does not prove runtime availability.",
          "items": {
            "type": "object"
          }
        },
        "keystone.agents.aliases": {
          "type": "array",
          "default": [],
          "description": "User aliases with an explicit aliasFor target. Aliases inherit only evidence-backed target availability.",
          "items": {
            "type": "object"
          }
        },
        "keystone.agents.rules": {
          "type": "array",
          "default": [],
          "description": "Deterministic task-category/capability to agent mappings used only for rule-based or fixed-workflow selection.",
          "items": {
            "type": "object"
          }
        },
        "keystone.copilot.enableTools": {
          "type": "boolean",
          "default": true,
          "description": "Register bounded read-only Keystone Intelligence tools when the VS Code Language Model Tool API is available."
        },
        "keystone.copilot.enableChatParticipant": {
          "type": "boolean",
          "default": true,
          "description": "Register the deterministic @keystone chat participant when supported."
        },
        "keystone.copilot.includeCandidateRelationships": {
          "type": "boolean",
          "default": false,
          "description": "Allow candidate relationships in Keystone tool results when explicitly requested."
        },
        "keystone.copilot.maximumToolResults": {
          "type": "number",
          "default": 25,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum result items returned by one Keystone tool invocation."
        },
        "keystone.copilot.maximumSourceExcerptLines": {
          "type": "number",
          "default": 20,
          "minimum": 0,
          "maximum": 100,
          "description": "Maximum source excerpt lines returned by one Keystone tool result."
        },
        "keystone.copilot.defaultAssistedMode": {
          "type": "string",
          "enum": [
            "open-chat",
            "clipboard"
          ],
          "default": "open-chat",
          "description": "Default safe fallback for assisted Copilot launch."
        },
        "keystone.copilot.customizationDiscoveryPaths": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional repository-relative allowlisted customization paths. Arbitrary user directories are never scanned."
        },
        "keystone.copilot.toolAuditRetention": {
          "type": "number",
          "default": 200,
          "minimum": 10,
          "maximum": 1000,
          "description": "Maximum bounded, source-free Keystone tool audit entries retained locally."
        },
        "keystone.validation.runBuild": {
          "type": "boolean",
          "default": true,
          "description": "Offer the detected build command during validation."
        },
        "keystone.validation.runLint": {
          "type": "boolean",
          "default": true,
          "description": "Offer the detected lint command during validation."
        },
        "keystone.validation.runTests": {
          "type": "boolean",
          "default": true,
          "description": "Offer the detected test command during validation."
        },
        "keystone.persistence.workspaceSpecifications": {
          "type": "boolean",
          "default": false,
          "description": "Store specifications in the repository. Disabled keeps them in extension-managed workspace storage."
        },
        "keystone.team.repositoryArtifactsEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Allow explicit handoff export under .keystone/handoffs. Keystone never commits the artifact automatically."
        },
        "keystone.logging.level": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warning",
            "error"
          ],
          "default": "info",
          "description": "Minimum level written to the Keystone output channel."
        }
      }
    }
  },
  "dependencies": {
    "@xyflow/react": "^12.11.2",
